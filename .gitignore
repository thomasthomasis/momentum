# ── Secrets — never commit these ─────────────────────────────────────────────
# .env.development CAN be committed (no real secrets, just localhost values)
# .env.production must NOT be committed
/.env.production
backend/.env.production
frontend/.env.production
extension/.env.production

# ── Frontend ──────────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.env.local

# ── Backend ───────────────────────────────────────────────────────────────────
backend/bin/
backend/obj/
backend/*.db
backend/*.db-shm
backend/*.db-wal

# ── Extension ─────────────────────────────────────────────────────────────────
# config.js is committed with dev defaults so the extension works out of the box.
# Re-generate for production with: node extension/build.js production

# ── Agent (Python tray app) ───────────────────────────────────────────────────
agent/.env
agent/venv/
agent/venv-windows/
agent/__pycache__/
agent/build/
# Windows sometimes holds a lock on the previous exe (antivirus scan, or the
# PyInstaller-run process itself), so rebuilds occasionally go to dist2/,
# dist3/, etc. rather than fighting the lock — all covered here.
agent/dist*/
agent/*.log
# The built .exe is a large binary artifact — rebuild via PyInstaller
# (see MomentumAgent.spec) rather than committing it, or attach it to a
# GitHub Release instead if you want a downloadable copy.
frontend/public/downloads/*.exe

# ── Tooling caches ────────────────────────────────────────────────────────────
.claude/
dotnet/

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.user

venv/