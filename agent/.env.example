# Copy to .env and adjust for your environment.
# This overrides config.py's default (the deployed production API) — use this
# for local development against a local docker-compose backend. Not read by
# the distributed .exe (PyInstaller's temp extraction path means .env doesn't
# travel with it), so the shipped installer always uses the production default.
MOMENTUM_API_BASE=http://localhost:5000/api/v1
MOMENTUM_AUTO_PAUSE_IDLE_SECONDS=90
MOMENTUM_FLUSH_INTERVAL_SECONDS=30
MOMENTUM_STATUS_POLL_SECONDS=5
